---
import Layout from "../layouts/Layout.astro";
import { env } from "cloudflare:workers";

const cfEnv = env as unknown as { GOOGLE_MAPS_API_KEY?: string };
const googleMapsApiKey = cfEnv.GOOGLE_MAPS_API_KEY ?? "";
---

<Layout title="Find Your Representatives | reps-contact">
  <header class="border-b border-warm-200 bg-white">
    <div class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
      <a href="/" class="flex items-center gap-2 text-navy-900 no-underline">
        <span class="text-xl">🏛️</span>
        <span class="text-sm font-semibold tracking-wide uppercase">reps-contact</span>
      </a>
      <a href="/docs" class="text-sm text-warm-600 hover:text-navy-900 transition-colors">API Docs</a>
    </div>
  </header>

  <main>
    <section class="px-6 pt-16 pb-12">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="font-display text-5xl leading-tight text-navy-900 sm:text-6xl sm:leading-tight">
          Find Your Representatives
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-warm-600">
          Enter your zip code to look up your senators and house representative, with direct contact information.
        </p>

        <form id="zip-form" class="mx-auto mt-10 flex max-w-sm gap-3">
          <input
            type="text"
            id="zip-input"
            name="zip"
            placeholder="Zip code"
            maxlength="5"
            pattern="[0-9]{5}"
            inputmode="numeric"
            required
            class="flex-1 rounded-lg border border-warm-300 bg-white px-4 py-3 text-lg text-warm-900 shadow-sm placeholder:text-warm-500 focus:border-navy-700 focus:outline-none focus:ring-2 focus:ring-navy-200"
            autocomplete="off"
            data-lpignore="true"
            data-form-type="other"
          />
          <button
            type="submit"
            class="rounded-lg bg-amber-600 px-6 py-3 text-lg font-medium text-white shadow-sm transition-colors hover:bg-amber-700 focus:outline-none focus:ring-2 focus:ring-amber-500/50 disabled:opacity-50"
          >
            Look Up
          </button>
        </form>

        <div id="error" class="mt-4 hidden text-sm text-red-600"></div>
      </div>
    </section>

    <div id="loading" class="hidden py-12 text-center text-warm-500">
      <svg class="mx-auto h-8 w-8 animate-spin text-navy-700" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <p class="mt-2">Looking up your representatives&hellip;</p>
    </div>

    <div id="ambiguous-notice" class="mx-auto mt-2 hidden max-w-2xl px-6">
      <div class="rounded-lg border border-amber-100 bg-amber-50 p-4 text-sm text-amber-700">
        <p class="font-medium">This zip code spans multiple congressional districts.</p>
        <p class="mt-1 text-amber-600">Enter your street address for an exact match.</p>
        <form id="address-form" class="mt-3 flex gap-2">
          <input
            type="text"
            id="address-input"
            placeholder="Start typing your address..."
            required
            autocomplete="off"
            class="flex-1 rounded-md border border-amber-200 bg-white px-3 py-2 text-sm text-warm-900 shadow-sm focus:border-navy-700 focus:outline-none focus:ring-2 focus:ring-navy-200"
          />
          <button
            type="submit"
            class="rounded-md bg-amber-600 px-4 py-2 text-sm font-medium text-white shadow-sm transition-colors hover:bg-amber-700 focus:outline-none focus:ring-2 focus:ring-amber-500/50 disabled:opacity-50"
          >
            Refine
          </button>
        </form>
        <p id="address-error" class="mt-2 hidden text-xs text-red-600"></p>
      </div>
    </div>

    <section class="mx-auto max-w-4xl px-6 pb-16">
      <div id="results" class="grid gap-4"></div>

      <div id="no-results" class="hidden py-12 text-center text-warm-500">
        <p class="text-lg">No representatives found for this zip code.</p>
        <p class="mt-1 text-sm">
          Make sure you entered a valid US zip code. Some territories may have
          non-voting delegates.
        </p>
      </div>
    </section>
  </main>

  <footer class="border-t border-warm-200 bg-white py-6 text-center text-sm text-warm-500">
    <p>
      Data sourced from official congressional records.
    </p>
  </footer>

  <span id="maps-config" data-key={googleMapsApiKey} class="hidden"></span>
</Layout>

<script>
  declare var google: any;

  const form = document.getElementById("zip-form") as HTMLFormElement;
  const input = document.getElementById("zip-input") as HTMLInputElement;
  const resultsDiv = document.getElementById("results")!;
  const loadingDiv = document.getElementById("loading")!;
  const errorDiv = document.getElementById("error")!;
  const noResultsDiv = document.getElementById("no-results")!;
  const ambiguousNotice = document.getElementById("ambiguous-notice")!;
  const addressForm = document.getElementById("address-form") as HTMLFormElement;
  const addressInput = document.getElementById("address-input") as HTMLInputElement;
  const addressError = document.getElementById("address-error")!;

  let currentZip = "";
  let placeJustSelected = false;

  // --- Bundle types ---
  interface BundleRep {
    type: "sen" | "rep";
    first_name: string;
    last_name: string;
    party: string;
    state: string;
    district: number | null;
    phone: string | null;
    url: string | null;
    contact_form: string | null;
    photo_url: string;
    office: string | null;
  }

  interface Bundle {
    generatedAt: string;
    reps: Record<string, BundleRep>;
    zips: Record<string, [string, number][]>;
  }

  // --- Lazy bundle loading ---
  let bundle: Bundle | null = null;
  let bundleError = false;

  const bundleReady: Promise<Bundle | null> = fetch("/reps-bundle.json")
    .then((res) => {
      if (!res.ok) throw new Error(`Bundle fetch failed: ${res.status}`);
      return res.json() as Promise<Bundle>;
    })
    .then((data) => {
      bundle = data;
      const age = Date.now() - new Date(data.generatedAt).getTime();
      if (age > 30 * 24 * 60 * 60 * 1000) {
        console.warn("reps-bundle.json is older than 30 days — data may be stale");
      }
      return data;
    })
    .catch((err) => {
      console.error("Failed to load reps bundle:", err);
      bundleError = true;
      return null;
    });

  // --- Build lookup indexes from bundle ---
  function buildIndexes(b: Bundle) {
    const senatorsByState = new Map<string, (BundleRep & { bioguide_id: string })[]>();
    const repsByDistrict = new Map<string, (BundleRep & { bioguide_id: string })[]>();

    for (const [id, rep] of Object.entries(b.reps)) {
      const entry = { ...rep, bioguide_id: id };
      if (rep.type === "sen") {
        const arr = senatorsByState.get(rep.state) || [];
        arr.push(entry);
        senatorsByState.set(rep.state, arr);
      } else {
        const key = `${rep.state}-${rep.district}`;
        const arr = repsByDistrict.get(key) || [];
        arr.push(entry);
        repsByDistrict.set(key, arr);
      }
    }

    return { senatorsByState, repsByDistrict };
  }

  // --- Zip lookup from bundle ---
  function lookupZip(b: Bundle, zip: string): { reps: Rep[]; ambiguous: boolean } {
    const entries = b.zips[zip];
    if (!entries || entries.length === 0) return { reps: [], ambiguous: false };

    const { senatorsByState, repsByDistrict } = buildIndexes(b);
    const ambiguous = entries.length > 1;
    const seen = new Set<string>();
    const reps: Rep[] = [];

    for (const [state, district] of entries) {
      for (const sen of senatorsByState.get(state) || []) {
        if (!seen.has(sen.bioguide_id)) {
          seen.add(sen.bioguide_id);
          reps.push(bundleRepToRep(sen));
        }
      }
      const key = `${state}-${district}`;
      for (const hr of repsByDistrict.get(key) || []) {
        if (!seen.has(hr.bioguide_id)) {
          seen.add(hr.bioguide_id);
          reps.push(bundleRepToRep(hr));
        }
      }
    }

    return { reps, ambiguous };
  }

  function bundleRepToRep(r: BundleRep & { bioguide_id: string }): Rep {
    return {
      bioguide_id: r.bioguide_id,
      type: r.type,
      first_name: r.first_name,
      last_name: r.last_name,
      party: r.party,
      state: r.state,
      district: r.district,
      phone: r.phone,
      url: r.url,
      contact_form: r.contact_form,
      photo_url: r.photo_url,
      office: r.office,
    };
  }

  const STORAGE_KEY = "repscontact-zip";

  // --- Zip search (instant from bundle) ---
  async function searchZip(zip: string) {
    currentZip = zip;
    try { localStorage.setItem(STORAGE_KEY, zip); } catch {}
    resultsDiv.innerHTML = "";
    errorDiv.classList.add("hidden");
    noResultsDiv.classList.add("hidden");
    ambiguousNotice.classList.add("hidden");
    addressInput.value = "";
    addressError.classList.add("hidden");

    if (bundleError) {
      showError("Representative data failed to load. Please refresh the page.");
      return;
    }

    if (!bundle) {
      loadingDiv.classList.remove("hidden");
      await bundleReady;
      loadingDiv.classList.add("hidden");
    }

    if (!bundle) {
      showError("Representative data failed to load. Please refresh the page.");
      return;
    }

    const result = lookupZip(bundle, zip);

    if (result.ambiguous) {
      ambiguousNotice.classList.remove("hidden");
    }

    if (result.reps.length === 0) {
      noResultsDiv.classList.remove("hidden");
      return;
    }

    renderReps(result.reps);
  }

  // --- As-you-type: trigger on 5 digits ---
  input.addEventListener("input", () => {
    const val = input.value.replace(/\D/g, "");
    input.value = val;
    if (val.length === 5) {
      searchZip(val);
    } else {
      resultsDiv.innerHTML = "";
      errorDiv.classList.add("hidden");
      noResultsDiv.classList.add("hidden");
      ambiguousNotice.classList.add("hidden");
    }
  });

  // --- Form submit (button / Enter) ---
  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const zip = input.value.trim();
    if (!/^\d{5}$/.test(zip)) {
      showError("Please enter a valid 5-digit zip code.");
      return;
    }
    searchZip(zip);
  });

  // --- Google Places Autocomplete ---
  function initGooglePlaces() {
    const apiKey = document.getElementById("maps-config")?.dataset.key;
    if (!apiKey) return;

    const script = document.createElement("script");
    script.src = `https://maps.googleapis.com/maps/api/js?key=${apiKey}&libraries=places&loading=async`;
    script.async = true;
    script.onload = setupAutocomplete;
    script.onerror = () => console.warn("Google Maps API failed to load");
    document.head.appendChild(script);
  }

  function setupAutocomplete() {
    if (typeof google === "undefined" || !google.maps?.places) return;

    const autocomplete = new google.maps.places.Autocomplete(addressInput, {
      componentRestrictions: { country: "us" },
      types: ["address"],
      fields: ["address_components", "geometry"],
    });

    autocomplete.addListener("place_changed", () => {
      const place = autocomplete.getPlace();
      if (!place.geometry?.location) return;

      placeJustSelected = true;
      setTimeout(() => { placeJustSelected = false; }, 300);

      const lat: number = place.geometry.location.lat();
      const lng: number = place.geometry.location.lng();

      const zipComponent = place.address_components?.find(
        (c: any) => c.types.includes("postal_code")
      );
      const placeZip: string | undefined = zipComponent?.short_name;

      if (placeZip && bundle) {
        const result = lookupZip(bundle, placeZip);
        if (!result.ambiguous && result.reps.length > 0) {
          ambiguousNotice.classList.add("hidden");
          renderReps(result.reps);
          return;
        }
      }

      refineByLatLng(lat, lng);
    });
  }

  async function refineByLatLng(lat: number, lng: number) {
    addressError.classList.add("hidden");
    loadingDiv.classList.remove("hidden");
    resultsDiv.innerHTML = "";
    noResultsDiv.classList.add("hidden");

    try {
      const res = await fetch(`/api/reps?lat=${lat}&lng=${lng}`);
      const data = await res.json();

      if (!res.ok || !data.representatives?.length) {
        addressError.textContent =
          "Could not determine your exact district. Showing all possible representatives.";
        addressError.classList.remove("hidden");
        fallbackToZip();
        return;
      }

      ambiguousNotice.classList.add("hidden");
      renderReps(data.representatives);
    } catch {
      addressError.textContent =
        "Address lookup failed. Showing all possible representatives.";
      addressError.classList.remove("hidden");
      fallbackToZip();
    } finally {
      loadingDiv.classList.add("hidden");
    }
  }

  // --- Address form submit (fallback for Census API geocoding) ---
  addressForm.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (placeJustSelected) return;

    const street = addressInput.value.trim();
    if (!street) return;

    addressError.classList.add("hidden");
    loadingDiv.classList.remove("hidden");
    resultsDiv.innerHTML = "";
    noResultsDiv.classList.add("hidden");

    const fullAddress = currentZip ? `${street}, ${currentZip}` : street;

    try {
      const res = await fetch(
        `/api/reps?address=${encodeURIComponent(fullAddress)}`
      );
      const data = await res.json();

      if (!res.ok) {
        addressError.textContent = data.error || "Geocoding failed.";
        addressError.classList.remove("hidden");
        fallbackToZip();
        return;
      }

      if (!data.representatives?.length) {
        addressError.textContent =
          "Could not match address. Showing all possible representatives.";
        addressError.classList.remove("hidden");
        fallbackToZip();
        return;
      }

      ambiguousNotice.classList.add("hidden");
      renderReps(data.representatives);
    } catch {
      addressError.textContent =
        "Address lookup failed. Showing all possible representatives.";
      addressError.classList.remove("hidden");
      fallbackToZip();
    } finally {
      loadingDiv.classList.add("hidden");
    }
  });

  function fallbackToZip() {
    if (!currentZip || !bundle) return;
    const result = lookupZip(bundle, currentZip);
    if (result.reps.length > 0) {
      renderReps(result.reps);
    }
  }

  function esc(s: string): string {
    const d = document.createElement("div");
    d.textContent = s;
    return d.innerHTML;
  }

  function showError(msg: string) {
    errorDiv.textContent = msg;
    errorDiv.classList.remove("hidden");
    loadingDiv.classList.add("hidden");
  }

  interface Rep {
    bioguide_id: string;
    type: "sen" | "rep";
    first_name: string;
    last_name: string;
    party: string;
    state: string;
    district: number | null;
    phone: string | null;
    url: string | null;
    contact_form: string | null;
    photo_url: string | null;
    office: string | null;
  }

  // --- Restore last zip on page load ---
  try {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved && /^\d{5}$/.test(saved)) {
      input.value = saved;
      searchZip(saved);
    }
  } catch {}

  function renderReps(reps: Rep[]) {
    reps.sort((a, b) => {
      if (a.type !== b.type) return a.type === "sen" ? -1 : 1;
      return a.last_name.localeCompare(b.last_name);
    });

    resultsDiv.innerHTML = reps.map((rep) => {
      const partyConfig: Record<string, { badge: string; border: string }> = {
        Republican: { badge: "bg-red-50 text-red-700 border border-red-200", border: "border-l-red-400" },
        Democrat: { badge: "bg-blue-50 text-blue-700 border border-blue-200", border: "border-l-blue-400" },
        Independent: { badge: "bg-violet-50 text-violet-700 border border-violet-200", border: "border-l-violet-400" },
      };
      const party = partyConfig[rep.party] ?? { badge: "bg-warm-100 text-warm-700 border border-warm-200", border: "border-l-warm-400" };
      const chamber = rep.type === "sen" ? "Senator" : "Representative";
      const districtLabel =
        rep.type === "rep" && rep.district !== null
          ? `${rep.state}-${String(rep.district).padStart(2, "0")}`
          : rep.state;
      const photoSrc =
        rep.photo_url ??
        `https://bioguide.congress.gov/photo/${rep.bioguide_id}.jpg`;

      return `
        <div class="overflow-hidden rounded-xl border border-warm-200 bg-white shadow-sm transition-shadow hover:shadow-md border-l-4 ${party.border}">
          <div class="flex gap-4 p-5">
            <img
              src="${esc(photoSrc)}"
              alt="${esc(rep.first_name)} ${esc(rep.last_name)}"
              class="h-28 w-24 rounded-lg object-cover"
              loading="lazy"
              onerror="this.src='/placeholder.svg'; this.onerror=null;"
            />
            <div class="flex min-w-0 flex-1 flex-col">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <h3 class="font-display text-xl leading-tight text-navy-900">
                    ${esc(rep.first_name)} ${esc(rep.last_name)}
                  </h3>
                  <p class="mt-0.5 text-sm text-warm-600">
                    ${esc(chamber)} · ${esc(districtLabel)}
                  </p>
                </div>
                <span class="inline-flex shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium ${party.badge}">
                  ${esc(rep.party)}
                </span>
              </div>
              ${rep.office ? `<p class="mt-1.5 text-xs text-warm-500">${esc(rep.office)}</p>` : ""}
              <div class="mt-auto flex flex-wrap gap-2 pt-3">
                ${
                  rep.phone
                    ? `<a href="tel:${esc(rep.phone)}" class="inline-flex items-center gap-1.5 rounded-md bg-emerald-50 px-3 py-1.5 text-xs font-medium text-emerald-700 transition-colors hover:bg-emerald-100">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    ${esc(rep.phone)}
                  </a>`
                    : ""
                }
                ${
                  rep.url
                    ? `<a href="${esc(rep.url)}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-md bg-navy-50 px-3 py-1.5 text-xs font-medium text-navy-700 transition-colors hover:bg-navy-100">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                    </svg>
                    Website</a>`
                    : ""
                }
                ${
                  rep.contact_form
                    ? `<a href="${esc(rep.contact_form)}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-md bg-amber-50 px-3 py-1.5 text-xs font-medium text-amber-700 transition-colors hover:bg-amber-100">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    Contact Form</a>`
                    : ""
                }
              </div>
            </div>
          </div>
        </div>
      `;
    }).join("");
  }

  // --- Initialize Google Places ---
  initGooglePlaces();
</script>
