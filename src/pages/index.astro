---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Find Your Representatives | reps-contact">
  <main class="mx-auto max-w-3xl px-4 py-12">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
        Find Your Representatives
      </h1>
      <p class="mt-4 text-lg text-gray-600">
        Enter your zip code to find your US congressional representatives and
        how to contact them.
      </p>
    </div>

    <form id="zip-form" class="mx-auto mt-8 flex max-w-md flex-col gap-3 sm:flex-row">
      <input
        type="text"
        id="zip-input"
        name="zip"
        placeholder="Enter zip code"
        maxlength="5"
        pattern="[0-9]{5}"
        inputmode="numeric"
        required
        class="flex-1 rounded-lg border border-gray-300 px-4 py-3 text-lg shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
        autocomplete="postal-code"
      />
      <button
        type="submit"
        class="rounded-lg bg-blue-600 px-6 py-3 text-lg font-medium text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:opacity-50"
      >
        Look Up
      </button>
    </form>

    <div id="error" class="mx-auto mt-4 hidden max-w-md text-center text-sm text-red-600"></div>

    <div id="loading" class="mt-8 hidden text-center text-gray-500">
      <svg class="mx-auto h-8 w-8 animate-spin text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <p class="mt-2">Looking up your representatives...</p>
    </div>

    <div id="ambiguous-notice" class="mx-auto mt-4 hidden max-w-md rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
      <p>This zip code spans multiple congressional districts. Enter your street address for an exact match.</p>
      <form id="address-form" class="mt-3 flex gap-2">
        <input
          type="text"
          id="address-input"
          placeholder="123 Main St, City, ST"
          required
          class="flex-1 rounded-md border border-amber-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
        />
        <button
          type="submit"
          class="rounded-md bg-amber-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-amber-700 focus:outline-none focus:ring-2 focus:ring-amber-500/50 disabled:opacity-50"
        >
          Refine
        </button>
      </form>
      <p id="address-error" class="mt-2 hidden text-xs text-red-600"></p>
    </div>

    <div id="results" class="mt-8 grid gap-4"></div>

    <div id="no-results" class="mt-8 hidden text-center text-gray-500">
      <p>No representatives found for this zip code.</p>
      <p class="mt-1 text-sm">
        Make sure you entered a valid US zip code. Some territories may have
        non-voting delegates.
      </p>
    </div>
  </main>

  <footer class="mt-12 border-t border-gray-200 py-6 text-center text-sm text-gray-500">
    <p>
      Data sourced from official congressional records. &middot;
      <a href="/api/reps?zip=98101" class="text-blue-600 hover:underline">API</a>
    </p>
  </footer>
</Layout>

<script>
  const form = document.getElementById("zip-form") as HTMLFormElement;
  const input = document.getElementById("zip-input") as HTMLInputElement;
  const resultsDiv = document.getElementById("results")!;
  const loadingDiv = document.getElementById("loading")!;
  const errorDiv = document.getElementById("error")!;
  const noResultsDiv = document.getElementById("no-results")!;
  const ambiguousNotice = document.getElementById("ambiguous-notice")!;
  const addressForm = document.getElementById("address-form") as HTMLFormElement;
  const addressInput = document.getElementById("address-input") as HTMLInputElement;
  const addressError = document.getElementById("address-error")!;

  let currentZip = "";

  // --- Bundle types ---
  interface BundleRep {
    type: "sen" | "rep";
    first_name: string;
    last_name: string;
    party: string;
    state: string;
    district: number | null;
    phone: string | null;
    url: string | null;
    contact_form: string | null;
    photo_url: string;
    office: string | null;
  }

  interface Bundle {
    generatedAt: string;
    reps: Record<string, BundleRep>;
    zips: Record<string, [string, number][]>;
  }

  // --- Lazy bundle loading ---
  let bundle: Bundle | null = null;
  let bundleError = false;

  const bundleReady: Promise<Bundle | null> = fetch("/reps-bundle.json")
    .then((res) => {
      if (!res.ok) throw new Error(`Bundle fetch failed: ${res.status}`);
      return res.json() as Promise<Bundle>;
    })
    .then((data) => {
      bundle = data;
      // Staleness check
      const age = Date.now() - new Date(data.generatedAt).getTime();
      if (age > 30 * 24 * 60 * 60 * 1000) {
        console.warn("reps-bundle.json is older than 30 days — data may be stale");
      }
      return data;
    })
    .catch((err) => {
      console.error("Failed to load reps bundle:", err);
      bundleError = true;
      return null;
    });

  // --- Build lookup indexes from bundle ---
  function buildIndexes(b: Bundle) {
    const senatorsByState = new Map<string, (BundleRep & { bioguide_id: string })[]>();
    const repsByDistrict = new Map<string, (BundleRep & { bioguide_id: string })[]>();

    for (const [id, rep] of Object.entries(b.reps)) {
      const entry = { ...rep, bioguide_id: id };
      if (rep.type === "sen") {
        const arr = senatorsByState.get(rep.state) || [];
        arr.push(entry);
        senatorsByState.set(rep.state, arr);
      } else {
        const key = `${rep.state}-${rep.district}`;
        const arr = repsByDistrict.get(key) || [];
        arr.push(entry);
        repsByDistrict.set(key, arr);
      }
    }

    return { senatorsByState, repsByDistrict };
  }

  // --- Zip lookup from bundle ---
  function lookupZip(b: Bundle, zip: string): { reps: Rep[]; ambiguous: boolean } {
    const entries = b.zips[zip];
    if (!entries || entries.length === 0) return { reps: [], ambiguous: false };

    const { senatorsByState, repsByDistrict } = buildIndexes(b);
    const ambiguous = entries.length > 1;
    const seen = new Set<string>();
    const reps: Rep[] = [];

    for (const [state, district] of entries) {
      // Add senators for this state (dedupe across entries)
      for (const sen of senatorsByState.get(state) || []) {
        if (!seen.has(sen.bioguide_id)) {
          seen.add(sen.bioguide_id);
          reps.push(bundleRepToRep(sen));
        }
      }
      // Add house rep for this district
      const key = `${state}-${district}`;
      for (const hr of repsByDistrict.get(key) || []) {
        if (!seen.has(hr.bioguide_id)) {
          seen.add(hr.bioguide_id);
          reps.push(bundleRepToRep(hr));
        }
      }
    }

    return { reps, ambiguous };
  }

  function bundleRepToRep(r: BundleRep & { bioguide_id: string }): Rep {
    return {
      bioguide_id: r.bioguide_id,
      type: r.type,
      first_name: r.first_name,
      last_name: r.last_name,
      party: r.party,
      state: r.state,
      district: r.district,
      phone: r.phone,
      url: r.url,
      contact_form: r.contact_form,
      photo_url: r.photo_url,
      office: r.office,
    };
  }

  // --- Zip search (instant from bundle) ---
  async function searchZip(zip: string) {
    currentZip = zip;
    resultsDiv.innerHTML = "";
    errorDiv.classList.add("hidden");
    noResultsDiv.classList.add("hidden");
    ambiguousNotice.classList.add("hidden");
    addressInput.value = "";
    addressError.classList.add("hidden");

    if (bundleError) {
      showError("Representative data failed to load. Please refresh the page.");
      return;
    }

    // If bundle isn't loaded yet, show loading briefly
    if (!bundle) {
      loadingDiv.classList.remove("hidden");
      await bundleReady;
      loadingDiv.classList.add("hidden");
    }

    if (!bundle) {
      showError("Representative data failed to load. Please refresh the page.");
      return;
    }

    const result = lookupZip(bundle, zip);

    if (result.ambiguous) {
      ambiguousNotice.classList.remove("hidden");
    }

    if (result.reps.length === 0) {
      noResultsDiv.classList.remove("hidden");
      return;
    }

    renderReps(result.reps);
  }

  // --- As-you-type: trigger on 5 digits ---
  input.addEventListener("input", () => {
    const val = input.value.replace(/\D/g, "");
    input.value = val; // strip non-digits
    if (val.length === 5) {
      searchZip(val);
    } else {
      // Clear results when input changes away from 5 digits
      resultsDiv.innerHTML = "";
      errorDiv.classList.add("hidden");
      noResultsDiv.classList.add("hidden");
      ambiguousNotice.classList.add("hidden");
    }
  });

  // --- Form submit (button / Enter) ---
  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const zip = input.value.trim();
    if (!/^\d{5}$/.test(zip)) {
      showError("Please enter a valid 5-digit zip code.");
      return;
    }
    searchZip(zip);
  });

  // --- Address refinement (still hits API) ---
  addressForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const street = addressInput.value.trim();
    if (!street) return;

    addressError.classList.add("hidden");
    loadingDiv.classList.remove("hidden");
    resultsDiv.innerHTML = "";
    noResultsDiv.classList.add("hidden");

    const fullAddress = currentZip ? `${street}, ${currentZip}` : street;

    try {
      const res = await fetch(
        `/api/reps?address=${encodeURIComponent(fullAddress)}`
      );
      const data = await res.json();

      if (!res.ok) {
        addressError.textContent = data.error || "Geocoding failed.";
        addressError.classList.remove("hidden");
        fallbackToZip();
        return;
      }

      if (!data.representatives?.length) {
        addressError.textContent =
          "Could not match address. Showing all possible representatives.";
        addressError.classList.remove("hidden");
        fallbackToZip();
        return;
      }

      ambiguousNotice.classList.add("hidden");
      renderReps(data.representatives);
    } catch (err) {
      addressError.textContent =
        "Address lookup failed. Showing all possible representatives.";
      addressError.classList.remove("hidden");
      fallbackToZip();
    } finally {
      loadingDiv.classList.add("hidden");
    }
  });

  function fallbackToZip() {
    if (!currentZip || !bundle) return;
    const result = lookupZip(bundle, currentZip);
    if (result.reps.length > 0) {
      renderReps(result.reps);
    }
  }

  function esc(s: string): string {
    const d = document.createElement("div");
    d.textContent = s;
    return d.innerHTML;
  }

  function showError(msg: string) {
    errorDiv.textContent = msg;
    errorDiv.classList.remove("hidden");
    loadingDiv.classList.add("hidden");
  }

  interface Rep {
    bioguide_id: string;
    type: "sen" | "rep";
    first_name: string;
    last_name: string;
    party: string;
    state: string;
    district: number | null;
    phone: string | null;
    url: string | null;
    contact_form: string | null;
    photo_url: string | null;
    office: string | null;
  }

  function renderReps(reps: Rep[]) {
    // Sort: senators first, then house reps
    reps.sort((a, b) => {
      if (a.type !== b.type) return a.type === "sen" ? -1 : 1;
      return a.last_name.localeCompare(b.last_name);
    });

    resultsDiv.innerHTML = reps.map((rep) => {
      const partyColors: Record<string, string> = {
        Republican: "bg-red-100 text-red-800",
        Democrat: "bg-blue-100 text-blue-800",
        Independent: "bg-purple-100 text-purple-800",
      };
      const partyColor = partyColors[rep.party] ?? "bg-gray-100 text-gray-800";
      const chamber = rep.type === "sen" ? "Senator" : "Representative";
      const districtLabel =
        rep.type === "rep" && rep.district !== null
          ? `${rep.state}-${String(rep.district).padStart(2, "0")}`
          : rep.state;
      const photoSrc =
        rep.photo_url ??
        `https://raw.githubusercontent.com/unitedstates/images/gh-pages/congress/225x275/${rep.bioguide_id}.jpg`;

      return `
        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm transition-shadow hover:shadow-md">
          <div class="flex gap-4 p-4">
            <img
              src="${esc(photoSrc)}"
              alt="${esc(rep.first_name)} ${esc(rep.last_name)}"
              class="h-24 w-20 rounded-md object-cover"
              loading="lazy"
              onerror="this.src='/placeholder.svg'; this.onerror=null;"
            />
            <div class="flex min-w-0 flex-1 flex-col">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <h3 class="text-lg font-semibold leading-tight">
                    ${esc(rep.first_name)} ${esc(rep.last_name)}
                  </h3>
                  <p class="text-sm text-gray-600">
                    ${esc(chamber)} &middot; ${esc(districtLabel)}
                  </p>
                </div>
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium ${partyColor}">
                  ${esc(rep.party)}
                </span>
              </div>
              ${rep.office ? `<p class="mt-1 text-xs text-gray-500">${esc(rep.office)}</p>` : ""}
              <div class="mt-auto flex flex-wrap gap-2 pt-2">
                ${
                  rep.phone
                    ? `<a href="tel:${esc(rep.phone)}" class="inline-flex items-center gap-1 rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 hover:bg-green-100">
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    ${esc(rep.phone)}
                  </a>`
                    : ""
                }
                ${
                  rep.url
                    ? `<a href="${esc(rep.url)}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 hover:bg-blue-100">Website</a>`
                    : ""
                }
                ${
                  rep.contact_form
                    ? `<a href="${esc(rep.contact_form)}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 rounded-md bg-indigo-50 px-2 py-1 text-xs font-medium text-indigo-700 hover:bg-indigo-100">Contact Form</a>`
                    : ""
                }
              </div>
            </div>
          </div>
        </div>
      `;
    }).join("");
  }
</script>
