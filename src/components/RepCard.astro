---
interface Props {
  bioguide_id: string;
  type: "sen" | "rep";
  first_name: string;
  last_name: string;
  party: string;
  state: string;
  district: number | null;
  phone: string | null;
  url: string | null;
  contact_form: string | null;
  photo_url: string | null;
  office: string | null;
}

const {
  bioguide_id,
  type,
  first_name,
  last_name,
  party,
  state,
  district,
  phone,
  url,
  contact_form,
  photo_url,
  office,
} = Astro.props;

const partyConfig: Record<string, { badge: string; border: string }> = {
  Republican: { badge: "bg-red-50 text-red-700 border border-red-200", border: "border-l-red-400" },
  Democrat: { badge: "bg-blue-50 text-blue-700 border border-blue-200", border: "border-l-blue-400" },
  Independent: { badge: "bg-violet-50 text-violet-700 border border-violet-200", border: "border-l-violet-400" },
};

const pConfig = partyConfig[party] ?? { badge: "bg-warm-100 text-warm-700 border border-warm-200", border: "border-l-warm-400" };
const chamber = type === "sen" ? "Senator" : "Representative";
const districtLabel =
  type === "rep" && district !== null
    ? `${state}-${district.toString().padStart(2, "0")}`
    : state;
const photoSrc =
  photo_url ??
  `https://bioguide.congress.gov/photo/${bioguide_id}.jpg`;
---

<div class:list={["overflow-hidden rounded-xl border border-warm-200 bg-white shadow-sm transition-shadow hover:shadow-md border-l-4", pConfig.border]}>
  <div class="flex gap-4 p-5">
    <img
      src={photoSrc}
      alt={`${first_name} ${last_name}`}
      class="h-28 w-24 rounded-lg object-cover"
      loading="lazy"
      onerror="this.src='/placeholder.svg'; this.onerror=null;"
    />
    <div class="flex min-w-0 flex-1 flex-col">
      <div class="flex items-start justify-between gap-2">
        <div>
          <h3 class="font-display text-xl leading-tight text-navy-900">
            {first_name} {last_name}
          </h3>
          <p class="mt-0.5 text-sm text-warm-600">
            {chamber} · {districtLabel}
          </p>
        </div>
        <span
          class:list={["inline-flex shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium", pConfig.badge]}
        >
          {party}
        </span>
      </div>

      {office && <p class="mt-1.5 text-xs text-warm-500">{office}</p>}

      <div class="mt-auto flex flex-wrap gap-2 pt-3">
        {phone && (
          <a
            href={`tel:${phone}`}
            class="inline-flex items-center gap-1.5 rounded-md bg-emerald-50 px-3 py-1.5 text-xs font-medium text-emerald-700 transition-colors hover:bg-emerald-100"
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {phone}
          </a>
        )}
        {url && (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-md bg-navy-50 px-3 py-1.5 text-xs font-medium text-navy-700 transition-colors hover:bg-navy-100"
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            Website
          </a>
        )}
        {contact_form && (
          <a
            href={contact_form}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-md bg-amber-50 px-3 py-1.5 text-xs font-medium text-amber-700 transition-colors hover:bg-amber-100"
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Contact Form
          </a>
        )}
      </div>
    </div>
  </div>
</div>
